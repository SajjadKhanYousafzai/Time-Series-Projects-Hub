# Environment variables — copy to .env and fill in your values
# Never commit .env to version control!

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
PROJECT_NAME="Hourly Energy Demand Forecasting Hub"

# ── API Settings ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=3600

# ── Forecasting Defaults ──────────────────────────────────────────────────────
DEFAULT_REGION=AEP
DEFAULT_MODEL=arima
DEFAULT_HORIZON=24
