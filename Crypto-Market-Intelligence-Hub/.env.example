# Environment Configuration
# Copy to .env and fill in real values.
# Never commit .env to git.

# ── Python ────────────────────────────────────────────────────────────────────
PYTHONUNBUFFERED=1
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO
LOG_FORMAT=text                  # text | json

# ── Data Paths ────────────────────────────────────────────────────────────────
DATA_PATH=data/raw
PROCESSED_PATH=data/processed
MODELS_PATH=data/models

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=changeme-generate-a-strong-secret-in-production
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ── Next.js Frontend ─────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── External APIs ────────────────────────────────────────────────────────────
COINMARKETCAP_API_KEY=
COINGECKO_API_KEY=              # Leave blank for free tier

# ── Cache ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ── Experiment Tracking (Optional) ───────────────────────────────────────────
MLFLOW_TRACKING_URI=            # e.g. http://localhost:5000 or mlflow:// URI

# ── Monitoring (Optional) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ── Vercel (CI/CD) ────────────────────────────────────────────────────────────
# VERCEL_TOKEN=                 # Set as GitHub secret, not here
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
